{
    "version": 2,
    "framework": "django",
    "builds": [
        {
            "src": "backend/paperwriter/wsgi.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/static/(.*)",
            "dest": "backend/static/$1"
        },
        {
            "src": "/(.*)",
            "dest": "backend/paperwriter/wsgi.py"
        }
    ]
}
