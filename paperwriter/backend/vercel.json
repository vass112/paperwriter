{
  "version": 2,
  "builds": [
    {
      "src": "paperwriter/wsgi.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "paperwriter/wsgi.py"
    }
  ],
  "functions": {
    "paperwriter/wsgi.py": {
      "maxDuration": 60
    }
  },
  "env": {
    "DJANGO_SETTINGS_MODULE": "paperwriter.settings"
  }
}
